{
  "display_information": {
    "name": "Slack AI Assistant",
    "description": "A Slack AI Assistant for Bolt SDK & AI",
    "background_color": "#1d1c1d"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Slack AI Assistant",
      "always_online": true
    },
    "agent_view": {
      "agent_description": "Ask questions, summarize context, and get guided help from an AI assistant.",
      "suggested_prompts": [
        {
          "title": "Summarize this channel",
          "message": "Summarize the current channel context."
        },
        {
          "title": "Draft a reply",
          "message": "Draft a concise reply for this discussion."
        },
        {
          "title": "Roll dice",
          "message": "Roll 2d6 and explain the result."
        }
      ]
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:join",
        "chat:write",
        "commands",
        "groups:history",
        "im:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "app_home_opened",
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
